<?xml version="1.0" encoding="utf-8"?>
<!--
    Cleartext (HTTP) is permitted globally. The sync server is always a user-owned
    LAN device (IP address) with no TLS certificate, so HTTP is intentional.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
