#!/bin/sh
set -e

echo "▶ Unit tests..."
./gradlew test

echo "▶ Checking for connected device..."
if ! adb devices 2>/dev/null | grep -q "device$"; then
    echo "✗ No Android device/emulator connected."
    echo "  Connect a device or start an emulator, then retry the commit."
    exit 1
fi

TEST_PKG="com.maroney.cleanshare.test"

echo "▶ Building APKs..."
./gradlew assembleDebugAndroidTest

echo "▶ Installing APKs..."
adb install -r app/build/outputs/apk/debug/app-debug.apk
adb install -r app/build/outputs/apk/androidTest/debug/app-debug-androidTest.apk

# Always remove the test APK when the script exits, pass or fail.
# shellcheck disable=SC2064 # It's fine here as it's a constant.
trap "adb uninstall $TEST_PKG 2>/dev/null || true" EXIT

echo "▶ Running instrumented tests..."
instrument_output=$(adb shell am instrument -w \
    "$TEST_PKG/androidx.test.runner.AndroidJUnitRunner" 2>&1)
echo "$instrument_output"
if echo "$instrument_output" | grep -q "FAILURES!!!"; then
    echo "✗ Instrumented tests failed."
    exit 1
fi

echo "✓ All tests passed."
